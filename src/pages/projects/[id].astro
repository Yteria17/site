---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---
<Base title={project.data.title}>
  <h1>{project.data.title} <span class="status">[{project.data.status}]</span></h1>
  <span class="entry-meta">{project.data.date.toISOString().slice(0, 10)}</span>
  {project.data.url && <> — <a href={project.data.url} target="_blank">{project.data.url}</a></>}
  <br />
  {project.data.tags.map(t => <span class="tag">{t}</span>)}
  <article>
    <Content />
  </article>
</Base>
