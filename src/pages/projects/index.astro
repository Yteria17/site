---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title="projets">
  <h1>projets</h1>
  <hr />
  {sorted.map(p => (
    <div class="entry">
      <a href={`/projects/${p.id}`}>{p.data.title}</a>
      <span class="status">[{p.data.status}]</span>
      <br />
      <span class="entry-meta">{p.data.description}</span>
      <br />
      <span class="entry-meta">
        {p.data.tags.map(t => <span class="tag">{t}</span>)}
      </span>
    </div>
  ))}
</Base>
